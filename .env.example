# --- Database ----------------------------------------------------------------
# Local Postgres:
#   DATABASE_URL="postgresql://jpc:jpc@localhost:5432/jpc_portal?schema=public"
# Neon (pooled URL works for Prisma 7+):
DATABASE_URL=""

# --- NextAuth (Auth.js v5) ---------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# --- File storage ------------------------------------------------------------
STORAGE_DRIVER="local"                # "local" | "s3"
LOCAL_UPLOADS_DIR="./uploads"

# S3-compatible (only when STORAGE_DRIVER=s3)
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""                        # optional: e.g. R2 or Minio endpoint

# --- Email (Nodemailer + Gmail) ---------------------------------------------
# Use a Gmail account with an App Password (not the regular password).
# https://support.google.com/accounts/answer/185833
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# --- Misc --------------------------------------------------------------------
INVITE_TOKEN_TTL_HOURS="72"
