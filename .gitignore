# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# local file storage (dev only)
/uploads

# npx skills (cross-tool agents convention — not used; Claude Code reads .claude/skills/)
/.agents/
/skills-lock.json

# Claude Code — user-specific state (project-shared config lives in .claude/settings.json)
/.claude/settings.local.json
/.claude/cache/
/.claude/local/
/.claude/.session

# Brainstorming companion artifacts
.superpowers/
